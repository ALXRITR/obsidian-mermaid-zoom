{
  "name": "obsidian-mermaid-zoom",
  "version": "2.0.6",
  "description": "Mermaid Toolkit: zoom & pan + label icons + theme loader for Obsidian",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "mermaid",
    "zoom",
    "icons",
    "theme"
  ],
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@iconify-json/clarity": "^1.2.4",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.117",
    "@types/node": "^20.10.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.0",
    "obsidian": "latest",
    "typescript": "^5.3.0"
  }
}
